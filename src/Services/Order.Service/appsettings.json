{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],

    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",

        "Yarp": "Information",

        "Microsoft.Hosting.Lifetime": "Information"
      }
    },

    "Enrich": [
      "FromLogContext"
    ],

    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj} {NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
